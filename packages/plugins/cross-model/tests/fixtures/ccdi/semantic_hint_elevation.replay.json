{
  "name": "semantic_hint_elevation",
  "description": "Prescriptive hint on detected topic -> elevated to candidate -> injected. Turn 1 detects hooks.pre_tool_use (no search results, stays detected). Turn 2 provides prescriptive hint with claim_excerpt matching hooks.pre_tool_use -> hint emits candidate -> search + inject.",
  "initial_registry": null,
  "inventory_snapshot": "test_inventory.json",
  "config": null,
  "turns": [
    {
      "turn_number": 1,
      "input_text": "How do I write a PreToolUse hook?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use"]
      },
      "expected_candidates": [
        {"topic_key": "hooks.pre_tool_use"}
      ],
      "search_results": {},
      "composed_target": null,
      "codex_reply_error": false
    },
    {
      "turn_number": 2,
      "input_text": "Tell me about deployment strategies",
      "source": "codex",
      "semantic_hints": [
        {"claim_index": 0, "hint_type": "prescriptive", "claim_excerpt": "PreToolUse hooks"}
      ],
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": null,
      "expected_candidates": [
        {"topic_key": "hooks.pre_tool_use"}
      ],
      "search_results": {
        "hooks.pre_tool_use": [
          {
            "chunk_id": "hooks#pretooluse",
            "category": "hooks",
            "score": 0.8,
            "content": "PreToolUse hooks run before tool execution.",
            "source_file": "https://example.com"
          }
        ]
      },
      "composed_target": null,
      "codex_reply_error": false
    }
  ],
  "assertions": {
    "cli_pipeline_sequence": [
      "classify",
      "dialogue-turn",
      "classify",
      "dialogue-turn",
      "build-packet",
      "build-packet"
    ],
    "final_registry_file_assertions": [
      {"path": "entries[0].topic_key", "operator": "equals", "expected": "hooks.pre_tool_use"},
      {"path": "entries[0].state", "operator": "equals", "expected": "injected"},
      {"path": "entries[0].coverage.injected_chunk_ids", "operator": "contains", "expected": "hooks#pretooluse"},
      {"path": "entries[0].suppression_reason", "operator": "is_null", "expected": null},
      {"path": "entries[0].deferred_reason", "operator": "is_null", "expected": null}
    ],
    "trace_assertions": [
      {"turn_index": 0, "operator": "assert_key_present", "expected": "turn"},
      {"turn_index": 1, "operator": "assert_key_present", "expected": "semantic_hints"}
    ]
  }
}
