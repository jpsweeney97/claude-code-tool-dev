{
  "name": "empty_build_skips_target_match",
  "description": "No search results provided for the candidate topic -> harness skips build-packet entirely. No target-match check needed since no packet is built. Only classify + dialogue-turn run.",
  "initial_registry": null,
  "inventory_snapshot": "test_inventory.json",
  "config": null,
  "turns": [
    {
      "turn_number": 1,
      "input_text": "How do I write a PreToolUse hook?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use"]
      },
      "expected_candidates": [
        {"topic_key": "hooks.pre_tool_use"}
      ],
      "search_results": {},
      "composed_target": "Some target that would normally trigger a match check",
      "codex_reply_error": false
    }
  ],
  "assertions": {
    "cli_pipeline_sequence": [
      "classify",
      "dialogue-turn"
    ],
    "cli_calls_absent": ["build-packet"],
    "final_registry_file_assertions": [
      {"path": "entries[0].topic_key", "operator": "equals", "expected": "hooks.pre_tool_use"},
      {"path": "entries[0].state", "operator": "equals", "expected": "detected"}
    ],
    "trace_assertions": [
      {"turn_index": 0, "operator": "assert_key_present", "expected": "turn"}
    ]
  }
}
