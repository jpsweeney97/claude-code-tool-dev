{
  "name": "negative_cache_prevents_retry",
  "description": "Turn 1: topic detected, weak results -> suppressed:weak_results. Turn 2: same text re-classifies the topic but it stays suppressed (negative cache effect: suppressed entry is not re-entered when docs_epoch unchanged). Verifies suppression stickiness.",
  "initial_registry": null,
  "inventory_snapshot": "test_inventory.json",
  "config": null,
  "turns": [
    {
      "turn_number": 1,
      "input_text": "How do I write a PreToolUse hook?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": "test-epoch-abc",
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use"]
      },
      "expected_candidates": [
        {"topic_key": "hooks.pre_tool_use"}
      ],
      "search_results": {
        "hooks.pre_tool_use": [
          {
            "chunk_id": "hooks#pretooluse-low",
            "category": "hooks",
            "score": 0.1,
            "content": "Barely relevant content about hooks.",
            "source_file": "https://example.com"
          }
        ]
      },
      "composed_target": null,
      "codex_reply_error": false
    },
    {
      "turn_number": 2,
      "input_text": "How do I write a PreToolUse hook?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": "test-epoch-abc",
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use"]
      },
      "expected_candidates": null,
      "search_results": {},
      "composed_target": null,
      "codex_reply_error": false
    }
  ],
  "assertions": {
    "cli_pipeline_sequence": [
      "classify",
      "dialogue-turn",
      "build-packet",
      "build-packet",
      "classify",
      "dialogue-turn"
    ],
    "final_registry_file_assertions": [
      {"path": "entries[0].topic_key", "operator": "equals", "expected": "hooks.pre_tool_use"},
      {"path": "entries[0].state", "operator": "equals", "expected": "suppressed"},
      {"path": "entries[0].suppression_reason", "operator": "equals", "expected": "weak_results"}
    ],
    "trace_assertions": [
      {"turn_index": 0, "operator": "assert_key_present", "expected": "turn"},
      {"turn_index": 1, "operator": "assert_key_present", "expected": "turn"}
    ]
  }
}
