{
  "name": "source_equivalence",
  "description": "source=codex and source=user produce identical candidates for same input text. Two turns with different source but same text. Both should produce the same candidate (hooks.pre_tool_use). First turn injects; second turn sees it as already injected.",
  "initial_registry": null,
  "inventory_snapshot": "test_inventory.json",
  "config": null,
  "turns": [
    {
      "turn_number": 1,
      "input_text": "How do I write a PreToolUse hook?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use"]
      },
      "expected_candidates": [
        {"topic_key": "hooks.pre_tool_use"}
      ],
      "search_results": {
        "hooks.pre_tool_use": [
          {
            "chunk_id": "hooks#pretooluse",
            "category": "hooks",
            "score": 0.8,
            "content": "PreToolUse hooks run before tool execution.",
            "source_file": "https://example.com"
          }
        ]
      },
      "composed_target": null,
      "codex_reply_error": false
    },
    {
      "turn_number": 2,
      "input_text": "How do I write a PreToolUse hook?",
      "source": "user",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use"]
      },
      "expected_candidates": null,
      "search_results": {},
      "composed_target": null,
      "codex_reply_error": false
    }
  ],
  "assertions": {
    "cli_pipeline_sequence": [
      "classify",
      "dialogue-turn",
      "build-packet",
      "build-packet",
      "classify",
      "dialogue-turn"
    ],
    "cli_calls_absent": [],
    "final_registry_file_assertions": [
      {"path": "entries[0].topic_key", "operator": "equals", "expected": "hooks.pre_tool_use"},
      {"path": "entries[0].state", "operator": "equals", "expected": "injected"}
    ],
    "trace_assertions": [
      {"turn_index": 0, "operator": "assert_key_present", "expected": "turn"},
      {"turn_index": 1, "operator": "assert_key_present", "expected": "turn"}
    ]
  }
}
