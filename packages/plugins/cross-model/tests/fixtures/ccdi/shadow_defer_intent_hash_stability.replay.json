{
  "name": "shadow_defer_intent_hash_stability",
  "description": "Same classifier input across two turns in shadow mode -> identical classify_result_hash in shadow_defer_intents. Two high topics detected, cooldown defers the second. Both turns use identical text, so the deferred topic produces the same hash. Verifies hash stability invariant.",
  "initial_registry": null,
  "inventory_snapshot": "test_inventory.json",
  "config": null,
  "turns": [
    {
      "turn_number": 1,
      "input_text": "How do I configure PreToolUse hooks and SKILL.md frontmatter?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": true,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use", "skills.frontmatter"],
        "min_resolved_count": 2
      },
      "expected_candidates": [
        {"topic_key": "hooks.pre_tool_use"}
      ],
      "search_results": {},
      "composed_target": null,
      "codex_reply_error": false
    },
    {
      "turn_number": 2,
      "input_text": "How do I configure PreToolUse hooks and SKILL.md frontmatter?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": true,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use", "skills.frontmatter"],
        "min_resolved_count": 2
      },
      "expected_candidates": null,
      "search_results": {},
      "composed_target": null,
      "codex_reply_error": false
    }
  ],
  "assertions": {
    "cli_pipeline_sequence": [
      "classify",
      "dialogue-turn",
      "classify",
      "dialogue-turn"
    ],
    "cli_calls_absent": ["build-packet"],
    "final_registry_file_assertions": [
      {"path": "entries[0].topic_key", "operator": "equals", "expected": "hooks.pre_tool_use"},
      {"path": "entries[0].state", "operator": "equals", "expected": "detected"},
      {"path": "entries[0].deferred_reason", "operator": "is_null", "expected": null},
      {"path": "entries[1].topic_key", "operator": "equals", "expected": "skills.frontmatter"},
      {"path": "entries[1].state", "operator": "equals", "expected": "detected"},
      {"path": "entries[1].deferred_reason", "operator": "is_null", "expected": null}
    ],
    "trace_assertions": [
      {"turn_index": 0, "operator": "assert_key_present", "expected": "shadow_suppressed"},
      {"turn_index": 1, "operator": "assert_key_present", "expected": "shadow_suppressed"}
    ]
  }
}
