{
  "name": "seed_medium_baseline",
  "description": "Medium-confidence leaf topic. Turn 1: frontmatter detected at medium -> count=1, below threshold (2), no candidate emitted. Turn 2: same text re-detected -> count=2, meets threshold, candidate emitted and injected. Verifies consecutive_medium_count persistence across turns.",
  "initial_registry": null,
  "inventory_snapshot": "test_inventory.json",
  "config": null,
  "turns": [
    {
      "turn_number": 1,
      "input_text": "frontmatter",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["skills.frontmatter"]
      },
      "expected_candidates": null,
      "search_results": {},
      "composed_target": null,
      "codex_reply_error": false
    },
    {
      "turn_number": 2,
      "input_text": "frontmatter",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["skills.frontmatter"]
      },
      "expected_candidates": [
        {"topic_key": "skills.frontmatter"}
      ],
      "search_results": {
        "skills.frontmatter": [
          {
            "chunk_id": "skills#frontmatter",
            "category": "skills",
            "score": 0.8,
            "content": "SKILL.md frontmatter defines skill metadata.",
            "source_file": "https://example.com"
          }
        ]
      },
      "composed_target": null,
      "codex_reply_error": false
    }
  ],
  "assertions": {
    "cli_pipeline_sequence": [
      "classify",
      "dialogue-turn",
      "classify",
      "dialogue-turn",
      "build-packet",
      "build-packet"
    ],
    "cli_calls_absent": [],
    "final_registry_file_assertions": [
      {"path": "entries[0].topic_key", "operator": "equals", "expected": "skills.frontmatter"},
      {"path": "entries[0].state", "operator": "equals", "expected": "injected"},
      {"path": "entries[0].consecutive_medium_count", "operator": "equals", "expected": 0},
      {"path": "entries[0].coverage.injected_chunk_ids", "operator": "contains", "expected": "skills#frontmatter"}
    ],
    "trace_assertions": [
      {"turn_index": 0, "operator": "assert_key_present", "expected": "turn"},
      {"turn_index": 1, "operator": "assert_key_present", "expected": "turn"}
    ]
  }
}
