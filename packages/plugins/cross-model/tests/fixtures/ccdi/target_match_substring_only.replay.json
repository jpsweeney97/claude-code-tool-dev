{
  "name": "target_match_substring_only",
  "description": "Composed target text classifies to the same topic via classify fallback (since candidates from dialogue-turn lack canonical_label, substring check always falls through). Target contains 'PreToolUse' which classifies to hooks.pre_tool_use -> target-relevant. Commit proceeds.",
  "initial_registry": null,
  "inventory_snapshot": "test_inventory.json",
  "config": null,
  "turns": [
    {
      "turn_number": 1,
      "input_text": "How do I write a PreToolUse hook?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use"]
      },
      "expected_candidates": [
        {"topic_key": "hooks.pre_tool_use"}
      ],
      "search_results": {
        "hooks.pre_tool_use": [
          {
            "chunk_id": "hooks#pretooluse",
            "category": "hooks",
            "score": 0.8,
            "content": "PreToolUse hooks run before tool execution.",
            "source_file": "https://example.com"
          }
        ]
      },
      "composed_target": "I need to understand PreToolUse hooks for my extension project",
      "codex_reply_error": false
    }
  ],
  "assertions": {
    "cli_pipeline_sequence": [
      "classify",
      "dialogue-turn",
      "build-packet",
      "classify",
      "build-packet"
    ],
    "cli_calls_absent": [],
    "final_registry_file_assertions": [
      {"path": "entries[0].topic_key", "operator": "equals", "expected": "hooks.pre_tool_use"},
      {"path": "entries[0].state", "operator": "equals", "expected": "injected"},
      {"path": "entries[0].coverage.injected_chunk_ids", "operator": "contains", "expected": "hooks#pretooluse"}
    ],
    "trace_assertions": [
      {"turn_index": 0, "operator": "assert_key_present", "expected": "commit"}
    ]
  }
}
