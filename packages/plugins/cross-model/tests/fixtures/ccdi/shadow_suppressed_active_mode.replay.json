{
  "name": "shadow_suppressed_active_mode",
  "description": "Active mode (shadow_mode=false): two high topics trigger cooldown on second. The second topic gets deferred:cooldown written to registry. Trace has shadow_suppressed=false.",
  "initial_registry": null,
  "inventory_snapshot": "test_inventory.json",
  "config": null,
  "turns": [
    {
      "turn_number": 1,
      "input_text": "How do I configure PreToolUse hooks and SKILL.md frontmatter?",
      "source": "codex",
      "semantic_hints": null,
      "shadow_mode": false,
      "docs_epoch": null,
      "expected_classifier_result": {
        "resolved_topic_keys": ["hooks.pre_tool_use", "skills.frontmatter"],
        "min_resolved_count": 2
      },
      "expected_candidates": [
        {"topic_key": "hooks.pre_tool_use"}
      ],
      "search_results": {
        "hooks.pre_tool_use": [
          {
            "chunk_id": "hooks#pretooluse",
            "category": "hooks",
            "score": 0.8,
            "content": "PreToolUse hooks run before tool execution.",
            "source_file": "https://example.com"
          }
        ]
      },
      "composed_target": null,
      "codex_reply_error": false
    }
  ],
  "assertions": {
    "cli_pipeline_sequence": [
      "classify",
      "dialogue-turn",
      "build-packet",
      "build-packet"
    ],
    "final_registry_file_assertions": [
      {"path": "entries[0].topic_key", "operator": "equals", "expected": "hooks.pre_tool_use"},
      {"path": "entries[0].state", "operator": "equals", "expected": "injected"},
      {"path": "entries[1].topic_key", "operator": "equals", "expected": "skills.frontmatter"},
      {"path": "entries[1].state", "operator": "equals", "expected": "deferred"},
      {"path": "entries[1].deferred_reason", "operator": "equals", "expected": "cooldown"},
      {"path": "entries[1].deferred_ttl", "operator": "equals", "expected": 3}
    ],
    "trace_assertions": [
      {"turn_index": 0, "operator": "assert_key_present", "expected": "shadow_suppressed"},
      {"turn_index": 0, "operator": "action", "expected": "replay_turn"}
    ]
  }
}
