{
  "mcpServers": {
    "codex": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "${CLAUDE_PLUGIN_ROOT}", "python", "${CLAUDE_PLUGIN_ROOT}/scripts/codex_shim.py"],
      "env": {
        "CODEX_SANDBOX": "seatbelt"
      }
    },
    "context-injection": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "${CLAUDE_PLUGIN_ROOT}/context-injection", "python", "-m", "context_injection"],
      "env": {
        "REPO_ROOT": "${PWD}"
      }
    }
  }
}
