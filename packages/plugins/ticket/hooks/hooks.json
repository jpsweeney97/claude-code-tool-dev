{
  "description": "Ticket engine guard — validates engine invocations and injects trust fields",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ticket_engine_guard.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
