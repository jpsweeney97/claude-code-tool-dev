{
  "name": "@claude-tools/claude-code-docs",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "smoke:startup": "timeout 30 node dist/index.js </dev/null",
    "smoke:refresh": "timeout 30 node dist/index.js </dev/null"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "stemmer": "^2.0.1",
    "yaml": "^2.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
