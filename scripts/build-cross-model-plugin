#!/usr/bin/env bash
# Syncs vendored context injection source into the cross-model plugin.
# Run before marketplace update when context injection code changes.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SRC="$REPO_ROOT/packages/context-injection"
DEST="$REPO_ROOT/packages/plugins/cross-model/context-injection"

if [ ! -d "$SRC" ]; then
    echo "error: source not found at $SRC" >&2
    exit 1
fi

rsync -a --delete \
    --exclude='.venv/' \
    --exclude='__pycache__/' \
    --exclude='tests/' \
    --exclude='.pytest_cache/' \
    --exclude='.ruff_cache/' \
    --exclude='.mypy_cache/' \
    --exclude='README.vendored.md' \
    "$SRC/" "$DEST/"

# Post-sync integrity check
if [ ! -f "$DEST/context_injection/__init__.py" ]; then
    echo "error: sync produced invalid output — missing __init__.py" >&2
    exit 1
fi

# Validate hook matchers reference the correct plugin name
PLUGIN_NAME=$(python3 -c "import json; print(json.load(open('$DEST/../.claude-plugin/plugin.json'))['name'])")
if ! grep -q "mcp__plugin_${PLUGIN_NAME}_codex__codex" "$DEST/../hooks/hooks.json"; then
    echo "error: hook matcher does not reference plugin name '${PLUGIN_NAME}'" >&2
    exit 1
fi

echo "Synced context-injection → cross-model plugin ($(find "$DEST/context_injection" -name '*.py' | wc -l | tr -d ' ') Python files)"
